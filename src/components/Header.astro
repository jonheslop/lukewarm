---
import HeaderLink from "./HeaderLink.astro";
import config from "../content/config/config.json";
import { Image } from "astro:assets";

import logo from "../assets/lukewarm-logo.png";
---

<header>
  <a href="/" title={config.seo.title}
    ><Image
      loading="eager"
      src={logo}
      width={256}
      height={103.25}
      alt="Lukewarm logo"
    />
  </a>
  <!-- <nav>
    <div class="internal-links">
      {
        config.nav.map((nav) => (
          <HeaderLink href={nav.link}>{nav.title}</HeaderLink>
        ))
      }
    </div>
  </nav> -->
</header>
<style>
  header {
    margin: 0;
    padding: 1em;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    header {
      padding: 1em 2em;
    }
  }

  h2 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: normal;
    letter-spacing: -0.0125rem;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .internal-links {
    display: flex;
    gap: 1rem;
  }
  nav a {
    color: var(--black);
    border-bottom: 2px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
</style>
